# Required when you want real AI generation.
# Get your key from the OpenAI API dashboard.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Default model for text generation.
# You can change this to another compatible OpenAI text model.
OPENAI_MODEL=gpt-4o-mini

# Local fallback mode:
# true  = app runs with mock AI output when OPENAI_API_KEY is missing
# false = app requires OPENAI_API_KEY
ALLOW_MOCK_AI=true

# RUNWAY API
RUNWAYML_API_SECRET=你的Runway API Key
RUNWAY_MODEL=gen4.5
RUNWAY_RATIO=720:1280