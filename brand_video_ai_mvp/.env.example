APP_ENV=development

# Database
DATABASE_URL=sqlite:///./test.db

# JWT Auth
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# CORS / Admin
CORS_ALLOWED_ORIGINS=
ADMIN_EMAILS=
APP_BASE_URL=http://localhost:8000

# Email Verification / Password Reset
# Leave SMTP_* empty in development to print verification/reset links to logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
ALLOW_MOCK_AI=true

# OpenAI Video / Sora
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SIZE=720x1280
VIDEO_POLL_INTERVAL_SECONDS=5
VIDEO_TIMEOUT_SECONDS=600

# Storage
STORAGE_BACKEND=local
LOCAL_VIDEO_STORAGE_DIR=static/generated_videos
